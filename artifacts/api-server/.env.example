# Env vars required by the api-server. On Railway, set these under
# Project → Variables. PORT is injected automatically by Railway — do not set it.

# Core
NODE_ENV=production
ALLOWED_ORIGIN=
DATABASE_URL=
LOG_LEVEL=info
BLOB_DIR=

# Mobile client
EXPO_PUBLIC_DOMAIN=
ANDROID_PACKAGE_NAME=com.ghostface.app

# Solana / payments
GHOST_WALLET_ADDRESS=
SOLANA_DEPLOYER_KEY=
SOLANA_RPC_URL=
SOLANA_DEVNET_RPC_URL=
PLAN_TERM_DAYS=

# Push notifications (APNs)
APNS_AUTH_KEY=
APNS_BUNDLE_ID=
APNS_ENV=
APNS_KEY_ID=
APNS_TEAM_ID=

# TURN (WebRTC)
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# Vonage
VONAGE_API_KEY=
VONAGE_API_SECRET=
