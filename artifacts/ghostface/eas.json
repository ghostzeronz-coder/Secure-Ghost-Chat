{
  "cli": { "version": ">= 16.0.0", "appVersionSource": "remote" },
  "build": {
    "development": {
      "node": "22.13.0",
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "android": { "buildType": "apk" }
    },
    "development:device": {
      "node": "22.13.0",
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": false },
      "android": { "buildType": "apk" }
    },
    "preview": {
      "node": "22.13.0",
      "distribution": "internal",
      "ios": { "simulator": false },
      "android": { "buildType": "apk" }
    },
    "production": {
      "node": "22.13.0",
      "autoIncrement": true,
      "ios": { "buildConfiguration": "Release", "distribution": "store" },
      "android": { "buildType": "app-bundle", "distribution": "store" }
    }
  },
  "submit": {
    "production": {
      "ios": { "ascAppId": "$APPLE_ASC_APP_ID" },
      "android": { "track": "production", "releaseStatus": "completed" }
    }
  }
}
