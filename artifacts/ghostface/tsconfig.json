{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@noble/curves/ed25519.js": ["./node_modules/@noble/curves/ed25519.d.ts"],
      "@noble/hashes/utils.js": ["./node_modules/@noble/hashes/utils.d.ts"],
      "@noble/hashes/hkdf.js": ["./node_modules/@noble/hashes/hkdf.d.ts"],
      "@noble/hashes/hmac.js": ["./node_modules/@noble/hashes/hmac.d.ts"],
      "@noble/hashes/pbkdf2.js": ["./node_modules/@noble/hashes/pbkdf2.d.ts"],
      "@noble/hashes/sha2.js": ["./node_modules/@noble/hashes/sha2.d.ts"],
      "@noble/ciphers/chacha.js": ["./node_modules/@noble/ciphers/chacha.d.ts"],
      "@noble/ciphers/utils.js": ["./node_modules/@noble/ciphers/utils.d.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts"
  ],
  "references": [
    {
      "path": "../../lib/api-client-react"
    }
  ]
}
